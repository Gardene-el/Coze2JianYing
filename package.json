{
  "name": "coze2jianying",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "cd apps/desktop && bun run dev",
    "dev:quick": "cd apps/desktop && bun run dev:quick",
    "dev:init": "cd apps/desktop && bun run dev:init",
    "dev:quick:init": "cd apps/desktop && bun run dev:quick:init",
    "build": "cd apps/desktop && bun run package:win",
    "lint": "biome check --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "remark --quiet --output --"
    ],
    "*.{js,jsx,ts,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/pro-components": "^2.8.10",
    "@lobehub/icons": "^5.0.0",
    "@lobehub/ui": "^5.5.0",
    "antd": "^6.2.1",
    "antd-style": "4.1.0",
    "axios": "^1.8.4",
    "lucide-react": "^0.562.0",
    "motion": "^12.29.0",
    "next-themes": "^0.4.6",
    "polished": "^4.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.3.0",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^19.6.1",
    "@lobehub/lint": "^2.1.5",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "pnpm": {}
}
