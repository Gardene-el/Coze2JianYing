{
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "target": "ESNext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "composite": true,
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/main/*"],
      "~common/*": ["./src/common/*"],
      "electron-liquid-glass": ["./src/main/types/electron-liquid-glass.d.ts"],
      "*": ["./*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/main/global.d.ts",
    "src/preload/**/*",
    "src/common/**/*",
    "electron-builder.js",
    "native-deps.config.js"
  ]
}
