{
  "name": "coze2jianying-desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Coze2JianYing Desktop Application",
  "homepage": "https://github.com/Gardene-el/Coze2JianYing",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gardene-el/Coze2JianYing.git"
  },
  "author": "Gardene-el",
  "main": "./dist/main/index.js",
  "scripts": {
    "build:main": "cross-env NODE_OPTIONS=--max-old-space-size=8192 electron-vite build",
    "build:run-unpack": "electron .",
    "dev": "bun run build:backend && electron-vite dev",
    "dev:static": "cross-env DESKTOP_RENDERER_STATIC=1 bun run dev",
    "download:agent-browser": "node scripts/download-agent-browser.mjs",
    "format": "biome format --write .",
    "i18n": "tsx scripts/i18nWorkflow/index.ts && lobe-i18n",
    "postinstall": "electron-builder install-app-deps",
    "install-isolated": "pnpm install",
    "lint": "bun run lint:ts && bun run type-check && bun run lint:circular",
    "lint:circular": "bun run lint:circular:main && bun run lint:circular:packages",
    "lint:circular:main": "dpdm src/**/*.ts  --no-warning --no-tree --exit-code circular:1 --no-progress -T true --skip-dynamic-imports circular",
    "lint:circular:packages": "dpdm packages/**/src/**/*.ts  --no-warning --no-tree --exit-code circular:1 --no-progress -T true --skip-dynamic-imports circular",
    "lint:md": "remark . --silent --output",
    "lint:ts": "biome check --write src tests",
    "build:backend": "python ../../scripts/build_workflow/build_python.py",
    "build:backend:quick": "node -e \"const f='resources/python/python.exe';if(require('fs').existsSync(f)){console.log('[skip] Python already built, skipping rebuild')}else{const {execSync}=require('child_process');execSync('python ../../scripts/build_workflow/build_python.py',{stdio:'inherit'})}\"",
    "package:win": "bun run build:backend && bun run build:main && electron-builder --win --config electron-builder.mjs  --publish never",
    "package:quick:win": "bun run build:backend:quick && bun run build:main && electron-builder --win --config electron-builder.mjs --publish never",
    "dev:quick": "bun run build:backend:quick && electron-vite dev",
    "dev:init": "bun run build:backend && cross-env VITE_FORCE_ONBOARDING=1 electron-vite dev",
    "dev:quick:init": "bun run build:backend:quick && cross-env VITE_FORCE_ONBOARDING=1 electron-vite dev",
    "start": "electron-vite preview",
    "test": "vitest --run",
    "type-check": "tsgo --noEmit -p tsconfig.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "update-server": "sh scripts/update-test/run-test.sh"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.4.1",
    "cloudflared": "^0.7.1",
    "fetch-socks": "^1.3.2",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@c2jy/tunnel-core": "workspace:*",
    "@c2jy/vite-plugins": "workspace:*",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@lobechat/desktop-bridge": "workspace:*",
    "@lobechat/electron-client-ipc": "workspace:*",
    "@lobehub/i18n-cli": "^1.25.1",
    "@lobehub/lint": "^2.1.5",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@t3-oss/env-core": "^0.13.8",
    "@types/async-retry": "^1.4.9",
    "@types/resolve": "^1.20.6",
    "@types/semver": "^7.7.1",
    "@types/set-cookie-parser": "^2.4.10",
    "@typescript/native-preview": "7.0.0-dev.20251210.1",
    "async-retry": "^1.3.3",
    "consola": "^3.4.2",
    "cookie": "^1.1.1",
    "cross-env": "^10.1.0",
    "diff": "^8.0.2",
    "electron": "41.0.2",
    "electron-builder": "^26.0.12",
    "electron-devtools-installer": "^3.2.0",
    "electron-is": "^3.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "electron-vite": "^5.0.0",
    "electron-window-state": "^5.0.3",
    "es-toolkit": "^1.43.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fetch-socks": "^1.3.2",
    "fflate": "^0.8.2",
    "fix-path": "^5.0.0",
    "get-port-please": "^3.2.0",
    "happy-dom": "^20.0.11",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "i18next": "^25.7.2",
    "just-diff": "^6.0.2",
    "remark-cli": "^12.0.1",
    "resolve": "^1.22.11",
    "semver": "^7.7.3",
    "set-cookie-parser": "^2.7.2",
    "superjson": "^2.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "node-mac-permissions": "^2.5.0"
  }
}
